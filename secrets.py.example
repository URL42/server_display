# secrets.py
# Copy this file to secrets.py and fill in real values.
# secrets.py is gitignored — never commit it.

# Wi-Fi
WIFI_SSID     = "your_ssid"
WIFI_PASSWORD = "your_password"

# n8n
N8N_BASE_URL = "https://n8n.yourdomain.com"
N8N_API_KEY  = "your_n8n_api_key"

# bossbitch (Tailscale hostname — no http://, no trailing slash)
BOSSBITCH_HOST = "bossbitch"
BOSSBITCH_PORT = 8001
