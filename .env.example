# ─────────────────────────────────────────────────────────────────
# server-display / bossbitch — environment config
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────

# ── Todoist ───────────────────────────────────────────────────────
# Your personal API token — found at:
# https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=your_todoist_api_token_here

# The project ID where your chore tasks live.
# Find it by running:
#   curl -s https://api.todoist.com/rest/v2/projects \
#     -H "Authorization: Bearer YOUR_TOKEN" | python3 -m json.tool
# Look for your chore project and copy the "id" value.
TODOIST_PROJECT_ID=your_project_id_here

# ── Database ──────────────────────────────────────────────────────
# Path inside the container — matches the Docker volume mount.
# Leave this as-is unless you change the volume path in docker-compose.yml.
DB_PATH=/data/bossbitch.db

# ── Server ────────────────────────────────────────────────────────
# Port the FastAPI server listens on inside the container.
# Also update docker-compose.yml ports if you change this.
PORT=8001
